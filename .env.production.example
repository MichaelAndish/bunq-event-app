# ── bunq Platform — production environment variables ───────────────────────
# Copy to .env and fill in values before running infra/bootstrap.sh
# All of these are also set as GitHub Actions secrets for CI/CD

# bunq API credentials (from bunq sandbox or production)
BUNQ_API_KEY=
BUNQ_INSTALLATION_TOKEN=
BUNQ_DEVICE_ID=
BUNQ_SESSION_TOKEN=
BUNQ_USER_ID=
BUNQ_ACCOUNT_ID=
BUNQ_USE_MOCK=false

# Anthropic
ANTHROPIC_API_KEY=

# Database (Aurora Serverless v2 in production)
DATABASE_URL=postgresql://bunq:<password>@<aurora-cluster-endpoint>:5432/bunq

# Storage (AWS S3 in production, MinIO locally)
STORAGE_ENDPOINT=https://s3.eu-west-1.amazonaws.com
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=bunq-media-<account-id>
STORAGE_PUBLIC_URL=https://bunq-media-<account-id>.s3.eu-west-1.amazonaws.com

# Backend server
PORT=9191
NODE_ENV=production
