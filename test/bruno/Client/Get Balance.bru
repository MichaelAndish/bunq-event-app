meta {
  name: Get Balance
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/client/balance
  body: none
  auth: none
}

params:query {
  userId: {{userId}}
  accountId: {{accountId}}
}

tests {
  test("returns 200", function () {
    expect(res.status).to.equal(200);
  });

  test("has balance field", function () {
    expect(res.body).to.have.property("balance");
  });

  test("has currency field", function () {
    expect(res.body).to.have.property("currency");
  });

  test("balance is a numeric string", function () {
    expect(parseFloat(res.body.balance)).to.be.a("number").and.above(0);
  });
}
