meta {
  name: Close bunq.me Tab
  type: http
  seq: 4
}

put {
  url: {{sandboxBaseUrl}}/user/{{userId}}/monetary-account-bank/{{accountId}}/bunqme-tab/{{tabUuid}}
  body: json
  auth: none
}

headers {
  X-Bunq-Client-Authentication: {{sessionToken}}
  X-Bunq-Client-Request-Id: bunqme-close-{{$timestamp}}
  X-Bunq-Language: en_US
  X-Bunq-Region: nl_NL
  X-Bunq-Geolocation: 0 0 0 0 000
  Content-Type: application/json
  User-Agent: BunqSandboxCollection/1.0
}

body:json {
  {
    "status": "CANCELLED"
  }
}

tests {
  test("returns 200", function () {
    expect(res.status).to.equal(200);
  });
}
