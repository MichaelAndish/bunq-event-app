meta {
  name: Generate Key Pair (run once)
  type: http
  seq: 3
}

get {
  url: {{sandboxBaseUrl}}/installation
  body: none
  auth: none
}

headers {
  X-Bunq-Client-Request-Id: keypair-check-{{$timestamp}}
  X-Bunq-Language: en_US
  X-Bunq-Region: nl_NL
  X-Bunq-Geolocation: 0 0 0 0 000
  User-Agent: BunqSandboxCollection/1.0
}

docs {
  # RSA key pair (no Bruno script — use OpenSSL)

  Bruno’s request scripts cannot use Node’s `crypto` module in safe mode. Generate PEM keys on your machine, then paste them into the **Sandbox** environment as `privateKeyPem` and `publicKeyPem` (Bruno UI: collection → Environments → Sandbox).

  **Generate a 2048-bit RSA key pair:**

  ```bash
  openssl genrsa -out bunq-client-private.pem 2048
  openssl rsa -in bunq-client-private.pem -pubout -out bunq-client-public.pem
  ```

  Copy the full file contents (including `-----BEGIN … KEY-----` lines) into the env vars. Keep newlines as in the PEM files.

  If you run `bru run` on the whole Setup folder, set `privateKeyPem` / `publicKeyPem` in the Sandbox environment **before** this step — they are no longer filled by a script.

  **This request:** `GET /installation` without credentials returns **403** from bunq — that response confirms the sandbox host is reachable. It does not create keys or an installation.

  The private key is used later to sign Payment requests (`X-Bunq-Client-Signature`). Back up `privateKeyPem` if you need to reuse the same installation.
}

tests {
  test("sandbox API is reachable", function () {
    expect(res.status).to.equal(403);
    expect(res.body).to.have.property("Error");
  });

  test("RSA PEMs are present in environment", function () {
    const priv = bru.getEnvVar("privateKeyPem");
    const pub = bru.getEnvVar("publicKeyPem");
    expect(priv).to.be.a("string").and.include("PRIVATE KEY");
    expect(pub).to.be.a("string").and.include("PUBLIC KEY");
  });
}
