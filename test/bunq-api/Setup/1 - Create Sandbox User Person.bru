meta {
  name: Create Sandbox User (Person)
  type: http
  seq: 1
}

post {
  url: {{sandboxBaseUrl}}/sandbox-user-person
  body: none
  auth: none
}

headers {
  X-Bunq-Client-Request-Id: sandbox-user-{{$timestamp}}
  X-Bunq-Language: en_US
  X-Bunq-Region: nl_NL
  X-Bunq-Geolocation: 0 0 0 0 000
  Content-Type: application/json
  User-Agent: BunqSandboxCollection/1.0
}

script:post-response {
  const body = res.body;
  if (body && body.Response) {
    const apiCredential = body.Response.find(r => r.ApiCredential);
    if (apiCredential) {
      bru.setEnvVar("apiKey", apiCredential.ApiCredential.api_key);
      console.log("Saved apiKey:", apiCredential.ApiCredential.api_key);
    }
  }
}

tests {
  test("returns 200", function () {
    expect(res.status).to.equal(200);
  });

  test("response has Response array", function () {
    expect(res.body).to.have.property("Response");
    expect(res.body.Response).to.be.an("array");
  });

  test("contains ApiCredential with api_key", function () {
    const apiCredential = res.body.Response.find(r => r.ApiCredential);
    expect(apiCredential).to.exist;
    expect(apiCredential.ApiCredential).to.have.property("api_key");
  });
}
